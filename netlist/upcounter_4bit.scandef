VERSION 5.5 ;
NAMESCASESENSITIVE ON ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN upcounter_4bit ;

SCANCHAINS 1 ;
  - chain1_seg1_clk_test_rising 
    + PARTITION p_clk_test_rising 
      MAXBITS 4
    + START PIN scan_in
    + FLOATING 
       count_reg[0] ( IN SI ) ( OUT Q ) 
       count_reg[1] ( IN SI ) ( OUT Q ) 
       count_reg[2] ( IN SI ) ( OUT Q ) 
       count_reg[3] ( IN SI ) ( OUT Q ) 
    + STOP PIN scan_out
;

END SCANCHAINS 
END DESIGN 
